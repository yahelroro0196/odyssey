#!/usr/bin/env bash
set -euo pipefail

PORT="${ODYSSEY_PORT:-4000}"

while [[ $# -gt 0 ]]; do
  case "$1" in
    --port) PORT="$2"; shift 2 ;;
    *) shift ;;
  esac
done

echo "Reloading Odyssey code..."
RESULT=$(curl -s -X POST "http://localhost:${PORT}/api/v1/reload" 2>/dev/null)

if [ -z "$RESULT" ]; then
  echo "Error: Odyssey is not running on port ${PORT}."
  exit 1
fi

echo "$RESULT" | python3 -m json.tool 2>/dev/null || echo "$RESULT"
