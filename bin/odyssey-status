#!/usr/bin/env bash
set -euo pipefail

ODYSSEY_ROOT="$(cd "$(dirname "$0")/.." && pwd)"
REPO_ROOT="$(git -C "$ODYSSEY_ROOT" rev-parse --show-superproject-working-tree 2>/dev/null || echo "$ODYSSEY_ROOT")"
PID_FILE="${REPO_ROOT}/.odyssey.pid"
PORT="${ODYSSEY_PORT:-4000}"

while [[ $# -gt 0 ]]; do
  case "$1" in
    --port) PORT="$2"; shift 2 ;;
    --help|-h)
      echo "Usage: odyssey-status [--port <N>]"
      exit 0 ;;
    *) shift ;;
  esac
done

if [ -f "$PID_FILE" ] && kill -0 "$(cat "$PID_FILE")" 2>/dev/null; then
  PID=$(cat "$PID_FILE")
  echo "Odyssey is running (PID ${PID})"
  echo "  Dashboard: http://localhost:${PORT}"
  echo ""
  curl -s "http://localhost:${PORT}/api/v1/state" 2>/dev/null | python3 -m json.tool 2>/dev/null || echo "  (API not responding yet)"
else
  echo "Odyssey is not running."
  [ -f "$PID_FILE" ] && rm -f "$PID_FILE"
  echo "  Start: $(dirname "$0")/odyssey-start"
fi
